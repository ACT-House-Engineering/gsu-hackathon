---
import {
  Button,
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
  Separator,
} from "@repo/ui";
import BaseLayout from "@/layouts/BaseLayout.astro";

const workshopMaterialsUrl = "https://link.act.house/bdx";
const eventHubUrl =
  "https://acthouse.notion.site/Build-Day-X-Innovation-Bootcamp-Georgia-State-University-3254a99790e080bd8281f7b14619a8eb";
const announcementUrl = "https://www.instagram.com/p/DVcWCH9FGyn/";
const eniUrl = "https://eni.gsu.edu/";
const launchUrl = "https://eni.gsu.edu/launchgsu/";

const title = "About - GSU Build Day Techie Workshop";
const description =
  "Public event context and workshop framing for the GSU Build Day Techie Workshop.";
---

<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-20 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h1 class="mb-6 text-4xl font-bold tracking-tight">
        About the workshop
      </h1>
      <p class="mx-auto max-w-3xl text-xl text-muted-foreground">
        The GSU Build Day Techie Workshop is the public-facing companion to the
        Agentic Engineering materials shared for Build Day X Innovation
        Bootcamp at Georgia State University.
      </p>
    </div>

    <section class="mb-20">
      <Card>
        <CardHeader>
          <CardTitle className="text-2xl">Build Day X context</CardTitle>
          <CardDescription>
            What the public announcement and event hub describe
          </CardDescription>
        </CardHeader>
        <CardContent className="space-y-4">
          <p class="text-muted-foreground">
            The ENIGSU announcement describes Build Day X as an intensive,
            fast-moving innovation environment for students who want to build
            at a professional level and turn ideas into working prototypes in
            just 24 hours.
          </p>
          <p class="text-muted-foreground">
            The same public promo highlights mentorship, workshops, and
            collaborative teams spanning architecture, design, technology, and
            creative disciplines. It also advertises up to $2,500 in prizes and
            lists FanDuel as a sponsor.
          </p>
        </CardContent>
      </Card>
    </section>

    <section class="mb-20">
      <h2 class="mb-8 text-center text-3xl font-bold tracking-tight">
        Why this repo exists
      </h2>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        <Card>
          <CardHeader>
            <CardTitle>🧠 Agentic Engineering</CardTitle>
            <CardDescription>
              The workshop content this repo is built around
            </CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              The public workshop materials show a clear sequence: simple
              prompting, talking to a dataset, and prototyping code. This repo
              now reflects that framing instead of generic product-marketing
              copy.
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>🌐 Workshop Companion App</CardTitle>
            <CardDescription>
              A working codebase for demos, links, and hands-on adaptation
            </CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              The repo keeps a modern full-stack setup in place so the workshop
              has a real app surface, API, auth layer, Cloudflare deployment
              shape, and D1-backed data layer to build on.
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>🧑‍🏫 Public Resource Hub</CardTitle>
            <CardDescription>
              Links to the materials participants can actually reach
            </CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              The README and overview site now point directly to the workshop
              materials, event hub, ENIGSU announcement, and Georgia State
              entrepreneurship pages instead of starter-kit resources.
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>☁️ Production-Style Stack</CardTitle>
            <CardDescription>
              Still useful as a real software foundation
            </CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Under the hood the app stays on Bun, React, Astro, Hono,
              Cloudflare Workers, and Cloudflare D1, which keeps the workshop
              grounded in a deployable architecture rather than a static slide
              deck.
            </p>
          </CardContent>
        </Card>
      </div>
    </section>

    <section class="mb-20">
      <h2 class="mb-8 text-center text-3xl font-bold tracking-tight">
        Public links
      </h2>

      <Card>
        <CardContent className="pt-6">
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <Button asChild>
              <a href={workshopMaterialsUrl} target="_blank" rel="noopener noreferrer">
                Open Workshop Materials
              </a>
            </Button>
            <Button variant="outline" asChild>
              <a href={eventHubUrl} target="_blank" rel="noopener noreferrer">
                Open Build Day X Event Hub
              </a>
            </Button>
            <Button variant="outline" asChild>
              <a href={announcementUrl} target="_blank" rel="noopener noreferrer">
                View ENIGSU Announcement
              </a>
            </Button>
            <Button variant="outline" asChild>
              <a href={eniUrl} target="_blank" rel="noopener noreferrer">
                Visit ENI at GSU
              </a>
            </Button>
            <Button variant="outline" asChild>
              <a href={launchUrl} target="_blank" rel="noopener noreferrer">
                Visit LaunchGSU
              </a>
            </Button>
          </div>
        </CardContent>
      </Card>
    </section>

    <Separator className="my-12" />

    <section class="text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">
        Start with the workshop flow
      </h2>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        The next page maps the public workshop progression from prompt design to
        dataset reasoning to code generation.
      </p>

      <div class="flex flex-col justify-center gap-4 sm:flex-row">
        <Button size="lg" asChild>
          <a href="/features">See Workshop Flow</a>
        </Button>
        <Button variant="outline" size="lg" asChild>
          <a href="/pricing">Open Resources</a>
        </Button>
      </div>
    </section>
  </div>
</BaseLayout>
