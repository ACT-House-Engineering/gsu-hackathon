---
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@repo/ui";
import BaseLayout from "@/layouts/BaseLayout.astro";

const title = "Workshop Flow - GSU Build Day Techie Workshop";
const description =
  "How the public Agentic Engineering workshop progresses from prompting to datasets to code prototypes.";

const stages = [
  {
    title: "Who are Techies?",
    icon: "🙋🏽",
    points: [
      "The workshop opens with a show of hands around common tools already in use.",
      "The public slides explicitly reference ChatGPT, Claude, Lovable, v0, Claude Code, Codex, and CLI-based agent tooling.",
      "That framing makes the session practical immediately instead of theoretical.",
    ],
  },
  {
    title: "Stage 1: Simple Prompt",
    icon: "🗣️",
    points: [
      "The first exercise starts simple: assign a role and give the model a clear job.",
      "The public materials use an automobile mechanic prompt to show how far a better framing can take a basic request.",
      "This stage is about clear intent, role assignment, and prompt sharing.",
    ],
  },
  {
    title: "Stage 2: Talking to a Dataset",
    icon: "🗂️",
    points: [
      "The second exercise moves beyond plain chat into structured context.",
      "The workshop example asks the model to use Google Takeout JSON data and recommend restaurants in Atlanta with explanations.",
      "This stage demonstrates that good AI work often starts with better context, not a fancier model.",
    ],
  },
  {
    title: "Stage 3: Prototyping Code",
    icon: "🧪",
    points: [
      "The third stage turns intent into implementation.",
      "The public example asks for a linted Python CLI shoe customizer with three interactive options.",
      "The workshop materials also link to public Replit and Gemini examples so participants can see the idea become runnable code.",
    ],
  },
  {
    title: "Build Day Context",
    icon: "🚀",
    points: [
      "The workshop sits inside a 24-hour prototype sprint rather than a classroom-only setting.",
      "The event materials emphasize mentorship, judging, collaborative teams, and final pitches.",
      "That pressure changes the goal: make progress fast, communicate clearly, and ship something real.",
    ],
  },
];

const tools = [
  { name: "ChatGPT", category: "Models" },
  { name: "Claude", category: "Models" },
  { name: "Codex", category: "Agentic coding" },
  { name: "Claude Code", category: "Agentic coding" },
  { name: "Google Takeout JSON", category: "Data context" },
  { name: "Replit", category: "Prototype runtime" },
  { name: "Gemini", category: "Example chat" },
  { name: "Cloudflare Workers", category: "Runtime" },
  { name: "Cloudflare D1", category: "Database" },
  { name: "React", category: "Frontend" },
  { name: "Bun", category: "Runtime" },
  { name: "TypeScript", category: "Language" },
];
---

<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-20 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h1 class="mb-6 text-4xl font-bold tracking-tight">
        Workshop flow
      </h1>
      <p class="mx-auto max-w-3xl text-xl text-muted-foreground">
        The public Agentic Engineering materials follow a simple arc: start
        with prompts, add richer context through data, then turn the result
        into a working prototype quickly enough to matter in a Build Day
        environment.
      </p>
    </div>

    {stages.map((stage) => (
      <section class="mb-20">
        <div class="mb-8 flex items-center">
          <span class="mr-4 text-4xl">{stage.icon}</span>
          <h2 class="text-3xl font-bold tracking-tight">{stage.title}</h2>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
          {stage.points.map((point) => (
            <Card>
              <CardContent className="pt-6">
                <p class="text-sm text-muted-foreground">{point}</p>
              </CardContent>
            </Card>
          ))}
        </div>
      </section>
    ))}

    <section class="mb-20 rounded-lg bg-muted/20 p-12">
      <h2 class="mb-8 text-center text-3xl font-bold tracking-tight">
        Example workshop prompts
      </h2>

      <Card>
        <CardHeader>
          <CardTitle>From prompt to prototype</CardTitle>
          <CardDescription>
            Condensed from the public workshop materials
          </CardDescription>
        </CardHeader>
        <CardContent>
          <pre class="overflow-x-auto rounded-lg bg-muted p-4">
            <code class="text-sm">{`1. ACT as an Automobile Mechanic

2. Use this Google Takeout List JSON data of the places I like and give me
   recommendations for restaurants I would like in Atlanta with reasons why I
   would like each recommendation.

3. Write a linted Python script for a CLI tool that asks users to
   interactively customize their shoes with 3 options.`}</code>
          </pre>
        </CardContent>
      </Card>
    </section>

    <section class="mb-20 rounded-lg bg-muted/20 p-12">
      <h2 class="mb-8 text-center text-3xl font-bold tracking-tight">
        Tools and stack around the workshop
      </h2>

      <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
        {tools.map((tool) => (
          <div class="rounded-lg border bg-background p-4">
            <div class="font-semibold">{tool.name}</div>
            <div class="text-xs text-muted-foreground">{tool.category}</div>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
