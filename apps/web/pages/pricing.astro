---
import {
  Button,
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@repo/ui";
import BaseLayout from "@/layouts/BaseLayout.astro";

const workshopMaterialsUrl = "https://link.act.house/bdx";
const workshopSourceUrl =
  "https://acthouse.notion.site/agentic-gsu?source=copy_link";
const eventHubUrl =
  "https://acthouse.notion.site/Build-Day-X-Innovation-Bootcamp-Georgia-State-University-3254a99790e080bd8281f7b14619a8eb";
const announcementUrl = "https://www.instagram.com/p/DVcWCH9FGyn/";
const eniUrl = "https://eni.gsu.edu/";
const launchUrl = "https://eni.gsu.edu/launchgsu/";

const title = "Resources - GSU Build Day Techie Workshop";
const description =
  "Public links and verified context for the GSU Build Day Techie Workshop.";

const resources = [
  {
    name: "Workshop Materials",
    description: "The short-link entry point used in the public workshop deck",
    features: [
      "Short link shared in the public materials",
      "Agentic Engineering workshop content",
      "Best starting point for participants",
    ],
    cta: "Open Materials",
    href: workshopMaterialsUrl,
    variant: "default" as const,
  },
  {
    name: "Event Hub",
    description: "The Build Day X x Georgia State University Notion hub",
    features: [
      "Build Day X Innovation Bootcamp page",
      "Staff/event framing and operations context",
      "Helpful for broader event understanding",
    ],
    cta: "Open Event Hub",
    href: eventHubUrl,
    variant: "outline" as const,
  },
  {
    name: "GSU Entrepreneurship Links",
    description: "Official Georgia State entrepreneurship ecosystem pages",
    features: [
      "ENI at GSU official site",
      "LaunchGSU startup program page",
      "Useful context beyond the workshop itself",
    ],
    cta: "Open LaunchGSU",
    href: launchUrl,
    variant: "outline" as const,
  },
];
---

<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-20 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h1 class="mb-6 text-4xl font-bold tracking-tight">
        Resources and public links
      </h1>
      <p class="mx-auto max-w-3xl text-xl text-muted-foreground">
        This page collects the public sources used to rebrand the repo around
        the actual workshop and event. It is intentionally link-heavy and
        interpretation-light.
      </p>
    </div>

    <div class="mb-20 grid grid-cols-1 gap-8 md:grid-cols-3">
      {resources.map((resource) => (
        <Card className={resource.variant === "default" ? "border-primary shadow-lg" : ""}>
          <CardHeader>
            <CardTitle className="text-2xl">{resource.name}</CardTitle>
            <CardDescription>{resource.description}</CardDescription>
          </CardHeader>
          <CardContent>
            <ul class="mb-6 space-y-3">
              {resource.features.map((feature) => (
                <li class="flex items-start">
                  <svg
                    class="mr-2 mt-0.5 h-5 w-5 flex-shrink-0 text-green-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  <span class="text-sm">{feature}</span>
                </li>
              ))}
            </ul>
            <Button variant={resource.variant} className="w-full" asChild>
              <a href={resource.href} target="_blank" rel="noopener noreferrer">
                {resource.cta}
              </a>
            </Button>
          </CardContent>
        </Card>
      ))}
    </div>

    <section class="mb-20">
      <h2 class="mb-8 text-center text-3xl font-bold tracking-tight">
        Frequently referenced facts
      </h2>

      <div class="mx-auto grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-2">
        <Card>
          <CardHeader>
            <CardTitle className="text-lg">What is Build Day X?</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              The public ENIGSU announcement describes it as an intensive,
              fast-moving innovation environment where students turn ideas into
              working prototypes in only 24 hours.
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">What support is advertised?</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              The announcement explicitly calls out mentorship, workshops, and
              collaborative teams across architecture, design, technology, and
              creative disciplines.
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">What does the Techie Workshop cover?</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              The public workshop materials focus on Agentic Engineering and
              show a progression from simple prompting to dataset reasoning to
              code prototyping.
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">What else is publicly named?</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              The ENIGSU promo mentions up to $2,500 in prizes and identifies
              FanDuel as a sponsor.
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">Which pages matter most?</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Start with the short link for workshop materials, then use the
              Build Day X event hub and the official GSU entrepreneurship pages
              for broader context.
            </p>
          </CardContent>
        </Card>
      </div>
    </section>

    <section class="rounded-lg bg-muted/20 p-12 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">
        Keep the useful links close
      </h2>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        These are the same public links used to update the README, metadata,
        and visible app copy in this repo.
      </p>

      <div class="flex flex-col justify-center gap-4 sm:flex-row">
        <Button size="lg" asChild>
          <a href={workshopSourceUrl} target="_blank" rel="noopener noreferrer">
            Open Workshop Source
          </a>
        </Button>
        <Button variant="outline" size="lg" asChild>
          <a href={announcementUrl} target="_blank" rel="noopener noreferrer">
            Open ENIGSU Announcement
          </a>
        </Button>
        <Button variant="outline" size="lg" asChild>
          <a href={eniUrl} target="_blank" rel="noopener noreferrer">
            Open ENI at GSU
          </a>
        </Button>
      </div>
    </section>
  </div>
</BaseLayout>
