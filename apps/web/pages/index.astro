---
import {
  Button,
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@repo/ui";
import BaseLayout from "@/layouts/BaseLayout.astro";

const workshopMaterialsUrl = "https://link.act.house/bdx";
const eventHubUrl =
  "https://acthouse.notion.site/Build-Day-X-Innovation-Bootcamp-Georgia-State-University-3254a99790e080bd8281f7b14619a8eb";
const announcementUrl = "https://www.instagram.com/p/DVcWCH9FGyn/";

const highlights = [
  {
    title: "⏱️ 24-Hour Build Pressure",
    description: "The public event framing is a fast prototype sprint",
    content:
      "Build Day X is described as a 24-hour innovation environment focused on getting from idea to working prototype quickly.",
  },
  {
    title: "🤖 Agentic Engineering",
    description: "This repo supports the Techie Workshop materials",
    content:
      "The workshop content moves from simple prompting to dataset reasoning to code prototyping using agentic tools and workflows.",
  },
  {
    title: "🧑‍🏫 Mentors, Judges, Workshops",
    description: "Support is part of the event promise",
    content:
      "The public materials call out mentorship, workshops, judging, and facilitator support as part of the bootcamp experience.",
  },
  {
    title: "🫱🏽‍🫲🏼 Interdisciplinary Teams",
    description: "Not just engineering-only collaboration",
    content:
      "The announcement explicitly mentions collaborative teams spanning architecture, design, technology, and creative disciplines.",
  },
  {
    title: "🏆 Real Stakes",
    description: "Build Day X is positioned as a serious student challenge",
    content:
      "The ENIGSU promo advertises up to $2,500 in prizes and frames the event as a place to build at a professional level.",
  },
  {
    title: "🎯 Practical Workshop Output",
    description: "Prompts, datasets, prototypes, and implementation",
    content:
      "The workshop examples include prompt engineering, working with exported user data, and generating runnable prototype code.",
  },
];

const tools = [
  "ChatGPT",
  "Claude",
  "Codex",
  "Claude Code",
  "Google Takeout JSON",
  "Replit",
  "Gemini",
  "Cloudflare Workers",
  "Cloudflare D1",
  "React",
  "Bun",
  "TypeScript",
];
---

<BaseLayout>
  <section class="bg-gradient-to-b from-background to-muted/20 px-4 py-20 sm:px-6 lg:px-8">
    <div class="container mx-auto text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.28em] text-primary">
        Build Day X Innovation Bootcamp
      </p>
      <h1 class="mb-6 text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
        GSU Build Day Techie Workshop
      </h1>
      <p class="mx-auto mb-8 max-w-3xl text-xl text-muted-foreground">
        This companion site supports the Agentic Engineering workshop at
        Georgia State University: a hands-on session that moves from simple
        prompting to dataset reasoning to code prototyping inside a 24-hour
        build environment.
      </p>
      <div class="flex flex-col justify-center gap-4 sm:flex-row">
        <Button size="lg" asChild>
          <a href={workshopMaterialsUrl} target="_blank" rel="noopener noreferrer">
            Open Workshop Materials
          </a>
        </Button>
        <Button variant="outline" size="lg" asChild>
          <a href={eventHubUrl} target="_blank" rel="noopener noreferrer">
            View Event Hub
          </a>
        </Button>
        <Button variant="outline" size="lg" asChild>
          <a href={announcementUrl} target="_blank" rel="noopener noreferrer">
            Read ENIGSU Announcement
          </a>
        </Button>
      </div>
    </div>
  </section>

  <section class="px-4 py-20 sm:px-6 lg:px-8">
    <div class="container mx-auto">
      <div class="mb-16 text-center">
        <h2 class="mb-4 text-3xl font-bold tracking-tight">
          What the public event materials promise
        </h2>
        <p class="mx-auto max-w-2xl text-lg text-muted-foreground">
          The current public sources frame Build Day X as a high-intensity,
          mentor-supported prototype sprint and the Techie Workshop as a
          practical introduction to agentic engineering.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {highlights.map((highlight) => (
          <Card>
            <CardHeader>
              <CardTitle>{highlight.title}</CardTitle>
              <CardDescription>{highlight.description}</CardDescription>
            </CardHeader>
            <CardContent>
              <p class="text-sm text-muted-foreground">{highlight.content}</p>
            </CardContent>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-muted/20 px-4 py-20 sm:px-6 lg:px-8">
    <div class="container mx-auto text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">
        Tools referenced in the workshop
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-lg text-muted-foreground">
        The workshop materials explicitly reference mainstream model products,
        agentic coding tools, data exports, and prototype environments.
      </p>

      <div class="grid grid-cols-2 gap-8 md:grid-cols-4 lg:grid-cols-6">
        {tools.map((tool) => (
          <div class="rounded-lg border bg-background p-4">
            <span class="font-medium">{tool}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="px-4 py-20 sm:px-6 lg:px-8">
    <div class="container mx-auto text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight">
        Explore the workshop flow
      </h2>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-muted-foreground">
        See how the session progresses from role-based prompting to dataset work
        to prototype generation, then jump into the resource hub for the public
        links that anchor this repo.
      </p>

      <div class="flex flex-col justify-center gap-4 sm:flex-row">
        <Button size="lg" asChild>
          <a href="/features">See Workshop Flow</a>
        </Button>
        <Button variant="outline" size="lg" asChild>
          <a href="/pricing">Open Resources</a>
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
